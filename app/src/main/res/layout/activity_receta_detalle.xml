<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".ui.RecetaDetalleActivity">

    <!-- Contenido Scrolleable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Imagen Superior (Header) -->
            <ImageView
                android:id="@+id/recipeLargeImage"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:scaleType="centerCrop"
                android:background="#EEEEEE"
                android:contentDescription="Foto de receta"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Capa de difuminado visual (Degradado) -->
            <View
                android:id="@+id/gradientOverlayReceta"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:background="@drawable/gradient_blur_overlay"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Tarjeta de Información Superpuesta -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-60dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@+id/recipeLargeImage">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:background="@color/white">

                    <!-- Indicador superior elegante -->
                    <View
                        android:layout_width="48dp"
                        android:layout_height="5dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="24dp"
                        android:background="#E0E0E0" />

                    <!-- Título (Medicamento) Editable -->
                    <EditText
                        android:id="@+id/recipeTitleDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Analizando receta..."
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textCapWords"
                        android:autofillHints="none"
                        android:letterSpacing="-0.02" />

                    <!-- Instrucciones Breves -->
                    <EditText
                        android:id="@+id/recipeDescriptionDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Instrucciones del tratamiento aparecerán aquí."
                        android:textAlignment="center"
                        android:textColor="#5F6368"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textMultiLine"
                        android:autofillHints="none" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="12dp"
                        android:background="#F1F3F4" />

                    <!-- Datos en Formato Lista -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Item: Dosis -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dosis"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_alignParentStart="true" />
                            <EditText
                                android:id="@+id/doseText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:layout_alignParentEnd="true"
                                android:inputType="text" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8F9FA"/>

                        <!-- Item: Frecuencia -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Frecuencia"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_alignParentStart="true" />
                            <EditText
                                android:id="@+id/freqText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:layout_alignParentEnd="true"
                                android:inputType="text" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8F9FA"/>

                        <!-- Item: Duración -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Duración"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_alignParentStart="true" />
                            <EditText
                                android:id="@+id/durationText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:layout_alignParentEnd="true"
                                android:inputType="text" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8F9FA"/>

                        <!-- Item: Cantidad a Tomar -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cantidad a tomar"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_alignParentStart="true" />
                            <EditText
                                android:id="@+id/qtyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:layout_alignParentEnd="true"
                                android:inputType="text" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8F9FA"/>

                        <!-- Item: Cantidad del Envase -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cantidad en envase"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_alignParentStart="true" />
                            <EditText
                                android:id="@+id/envaseText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:layout_alignParentEnd="true"
                                android:inputType="text" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8F9FA"/>

                        <!-- Item: Veces al día -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Veces al día"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_alignParentStart="true" />
                            <EditText
                                android:id="@+id/timesText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:layout_alignParentEnd="true"
                                android:inputType="text" />
                        </RelativeLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="12dp"
                        android:background="#F1F3F4" />

                    <!-- Sección: Método de uso/consumo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Método de uso / consumo"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/useMethodText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="12dp"
                        android:text="Cargando indicaciones de uso..."
                        android:textColor="#5F6368"
                        android:textSize="15sp"
                        android:background="@drawable/rounded_dialog_bg"
                        android:backgroundTint="#F8F9FA"
                        android:enabled="false"
                        android:inputType="textMultiLine"
                        android:lineSpacingExtra="4dp" />

                    <!-- Espacio antes de los botones -->
                    <View android:layout_width="match_parent" android:layout_height="32dp" />

                    <!-- Acciones Finales Modernizadas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Botón Empezar Tratamiento -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnEmpezarTratamiento"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="18dp"
                            app:cardBackgroundColor="@color/Celeste"
                            app:cardElevation="4dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="EMPEZAR TRATAMIENTO"
                                    android:textColor="@color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Botón Principal Guardar -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnConfirmarIA"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:layout_marginTop="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="18dp"
                            app:cardBackgroundColor="#202124"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/textBtnConfirmar"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GUARDAR CAMBIOS"
                                    android:textColor="@color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Botones de Acción Secundarios -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAgregarManualmente"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="EDITAR"
                                android:textColor="@color/Celeste"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                app:icon="@android:drawable/ic_menu_edit"
                                app:iconTint="@color/Celeste"
                                app:iconGravity="textStart" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="24dp"
                                android:background="#DADCE0" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnEliminarReceta"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="ELIMINAR"
                                android:textColor="#D93025"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                app:icon="@android:drawable/ic_menu_delete"
                                app:iconTint="#D93025"
                                app:iconGravity="textStart" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Padding inferior extra para scroll -->
                    <View android:layout_width="match_parent" android:layout_height="40dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón Volver Refinado -->
    <ImageButton
        android:id="@+id/backButtonDetail"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:background="@drawable/circle_white_bg"
        android:elevation="8dp"
        android:src="@drawable/abc_ic_ab_back_material"
        android:contentDescription="Atrás"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#1E293B" />

    <!-- Cargando Overlay Moderno -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loadingIAOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        android:elevation="30dp"
        android:clickable="true"
        android:focusable="true">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieAnalyzingRecipe"
            android:layout_width="280dp"
            android:layout_height="280dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/cargando"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.4" />

        <TextView
            android:id="@+id/loadingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Interpretando tu receta médica..."
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lottieAnalyzingRecipe" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estamos extrayendo las dosis y frecuencias"
            android:textColor="#5F6368"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/loadingTitle"
            android:layout_marginTop="8dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>