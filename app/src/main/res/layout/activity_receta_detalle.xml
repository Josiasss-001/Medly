<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".ui.RecetaDetalleActivity">

    <!-- Contenido Scrolleable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Imagen Superior (Header) -->
            <ImageView
                android:id="@+id/recipeLargeImage"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:scaleType="centerCrop"
                android:background="#EEEEEE"
                android:contentDescription="Foto de receta"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Capa de difuminado visual (Degradado) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="@drawable/gradient_blur_overlay"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Tarjeta de Información Superpuesta -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                app:cardCornerRadius="40dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@+id/recipeLargeImage">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@color/white">

                    <!-- Indicador superior -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="20dp"
                        android:background="#EEEEEE" />

                    <!-- Título (Medicamento) Editable -->
                    <EditText
                        android:id="@+id/recipeTitleDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Analizando receta..."
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textCapWords"
                        android:autofillHints="none" />

                    <!-- Instrucciones Breves -->
                    <EditText
                        android:id="@+id/recipeDescriptionDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Instrucciones del tratamiento aparecerán aquí."
                        android:textAlignment="center"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:lineSpacingExtra="3dp"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textMultiLine"
                        android:autofillHints="none" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="#F0F0F0" />

                    <!-- Datos en Formato Lista Vertical -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <!-- Item: Dosis -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Dosis"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/doseText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="text"
                                android:autofillHints="none" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9"/>

                        <!-- Item: Frecuencia -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Frecuencia"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/freqText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="text"
                                android:autofillHints="none" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9"/>

                        <!-- Item: Duración -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Duración"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/durationText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="text"
                                android:autofillHints="none" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9"/>

                        <!-- Item: Cantidad a Tomar -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cantidad a tomar"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/qtyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="text"
                                android:autofillHints="none" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9"/>

                        <!-- Item: Cantidad del Envase -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cantidad en envase"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/envaseText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="text"
                                android:autofillHints="none" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9"/>

                        <!-- Item: Veces al día -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Veces al día"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/timesText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="text"
                                android:autofillHints="none" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="#F0F0F0" />

                    <!-- Sección: Método de uso/consumo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Método de uso/consumo"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/useMethodText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Cargando indicaciones de uso..."
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textMultiLine"
                        android:autofillHints="none" />

                    <!-- Espacio antes de los botones -->
                    <View android:layout_width="match_parent" android:layout_height="24dp" />

                    <!-- Botón Empezar Tratamiento -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnEmpezarTratamiento"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/Celeste"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EMPEZAR TRATAMIENTO"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Botón Principal Guardar -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnConfirmarIA"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#333333"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/textBtnConfirmar"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GUARDAR CAMBIOS"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Botón para Editar / Agregar Manualmente -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAgregarManualmente"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:text="EDITAR INFORMACIÓN"
                        android:textColor="@color/Celeste"
                        android:textStyle="bold"
                        app:cornerRadius="20dp" />

                    <!-- Botón para Eliminar Receta -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEliminarReceta"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="4dp"
                        android:text="ELIMINAR RECETA"
                        android:textColor="#FF3B30"
                        android:textStyle="bold"
                        app:cornerRadius="20dp" />

                    <!-- Padding inferior extra para scroll -->
                    <View android:layout_width="match_parent" android:layout_height="80dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón Volver Flotante -->
    <ImageButton
        android:id="@+id/backButtonDetail"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/abc_ic_ab_back_material"
        android:contentDescription="Atrás"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <!-- Cargando Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loadingIAOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6FFFFFF"
        android:visibility="gone"
        android:elevation="10dp">
        <ProgressBar
            android:id="@+id/progressBarDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/Celeste"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="La IA está leyendo tu receta..."
            android:textColor="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressBarDetail" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
