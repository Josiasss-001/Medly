<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- BARRA DE NAVEGACIÓN INFERIOR CENTRALIZADA -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tarjetaNavInferior"
        android:layout_width="match_parent"
        android:layout_height="115dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="0dp"
        android:layout_marginBottom="0dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="0dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="top"
            android:layout_marginHorizontal="0dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:weightSum="5">

            <ImageView
                android:id="@+id/botonInicioNav"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:clickable="true"
                android:contentDescription="Inicio"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/casa"
                app:tint="@color/colorIconosNav" />

            <ImageView
                android:id="@+id/botonDocsNav"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:clickable="true"
                android:contentDescription="Documentos"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/documento"
                app:tint="@color/colorIconosNav" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/botonMapasNav"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:clickable="true"
                android:contentDescription="Mapas"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ubi"
                app:tint="@color/colorIconosNav" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/botonPerfilNav"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:contentDescription="Perfil"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:padding="1dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/monito"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="@color/colorIconosNav"
                    app:strokeWidth="2dp" />
            </FrameLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- BOTÓN CENTRAL DE ESCANEO -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contenedorEscaner"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="55dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="#53c899"
        app:cardCornerRadius="32.5dp"
        app:cardElevation="15dp"
        app:strokeColor="@color/white"
        app:strokeWidth="3dp">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieEscaner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/qr" />
    </com.google.android.material.card.MaterialCardView>

</merge>
