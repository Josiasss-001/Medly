<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <!-- BOTÓN DE MENÚ HAMBURGUESA FLOTANTE -->
    <ImageView
        android:id="@+id/menuIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="50dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Menú"
        android:elevation="15dp"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_sort_by_size"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/Celeste" />

    <!-- CONTENEDOR DEL MAPA Y VENTANA FLOTANTE -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- MAPA -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:context=".ui.MapaActivity" />

        <!-- VENTANA FLOTANTE (Bottom Sheet) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottomSheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:strokeWidth="0dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            app:behavior_peekHeight="220dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Indicador visual -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="5dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:background="#E2E8F0" />

                <!-- Lista de Farmacias -->
                <LinearLayout
                    android:id="@+id/layoutList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Farmacias cercanas"
                        android:textColor="#0F172A"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- Indicador de carga -->
                    <ProgressBar
                        android:id="@+id/pbSearching"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:layout_marginVertical="10dp"
                        android:visibility="gone" />

                    <!-- Mensaje de estado -->
                    <TextView
                        android:id="@+id/tvNoResultsMapa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Buscando farmacias reales..."
                        android:textAlignment="center"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFarmacias"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>

                <!-- Detalle de la Farmacia -->
                <LinearLayout
                    android:id="@+id/layoutDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvFarmaciaNombre"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Nombre Farmacia"
                            android:textColor="#0F172A"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@+id/btnBack"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageButton
                            android:id="@+id/btnBack"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Cerrar detalle"
                            android:src="@android:drawable/ic_menu_close_clear_cancel"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#64748B" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <ProgressBar
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="12dp"
                        android:progress="100"
                        android:progressTint="@color/Celeste" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:columnCount="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Distancia real"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvDistancia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- km"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tiempo estimado"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvTiempo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- min"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </GridLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnComenzar"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="32dp"
                        android:text="Comenzar Navegación"
                        android:backgroundTint="@color/Celeste"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="18dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- NUEVA BARRA DE NAVEGACIÓN PERSONALIZADA -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="55dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="35dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeWidth="0dp"
        tools:layout_editor_absoluteX="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:weightSum="5">

            <ImageView
                android:id="@+id/btnHomeNav"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:clickable="true"
                android:contentDescription="Inicio"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="2dp"
                android:src="@drawable/house" />

            <ImageView
                android:id="@+id/btnRecetasNav"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:clickable="true"
                android:contentDescription="Recetas"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="2dp"
                android:src="@drawable/archivo" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btnMapasNav"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:clickable="true"
                android:contentDescription="Mapas"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="2dp"
                android:src="@drawable/maps" />

            <ImageView
                android:id="@+id/btnPerfilNav"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:clickable="true"
                android:contentDescription="Perfil"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="2dp"
                android:src="@drawable/monito" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/scanContainer"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:layout_marginBottom="55dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:cardBackgroundColor="@color/Celeste"
        app:cardCornerRadius="37.5dp"
        app:cardElevation="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/white"
        app:strokeWidth="4dp">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieScan"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:padding="15dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/qr" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
