<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.CalendarioTratamientoActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8FAFC">

        <!-- CONTENEDOR PRINCIPAL DEL CALENDARIO: Ocupa todo el ancho, con sombra y bordes redondeados -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvContenedorCalendario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="20dp">

                <!-- Título Superior dentro del contenedor -->
                <TextView
                    android:id="@+id/tvTituloCalendario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:text="Mi Calendario de Salud"
                    android:textColor="#1E293B"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Barra de herramientas (Atrás y Selector de Mes centrado) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clBarraHerramientas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tvTituloCalendario">

                    <ImageButton
                        android:id="@+id/btnAtras"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Volver"
                        android:src="@drawable/abc_ic_ab_back_material"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#1E293B" />

                    <LinearLayout
                        android:id="@+id/llSelectorMes"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/calendar_month_pill_bg"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageButton
                            android:id="@+id/btnMesAnterior"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Mes anterior"
                            android:src="@android:drawable/ic_media_previous"
                            app:tint="#64748B" />

                        <TextView
                            android:id="@+id/tvMesActual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="Febrero"
                            android:textColor="#1E293B"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnMesSiguiente"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Mes siguiente"
                            android:src="@android:drawable/ic_media_next"
                            app:tint="#64748B" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Cabecera de días -->
                <LinearLayout
                    android:id="@+id/llDiasSemana"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:weightSum="7"
                    app:layout_constraintTop_toBottomOf="@id/clBarraHerramientas">
                    <TextView style="@style/CalendarDayHeader" android:text="Lu" />
                    <TextView style="@style/CalendarDayHeader" android:text="Ma" />
                    <TextView style="@style/CalendarDayHeader" android:text="Mi" />
                    <TextView style="@style/CalendarDayHeader" android:text="Ju" />
                    <TextView style="@style/CalendarDayHeader" android:text="Vi" />
                    <TextView style="@style/CalendarDayHeader" android:text="Sa" />
                    <TextView style="@style/CalendarDayHeader" android:text="Do" />
                </LinearLayout>

                <!-- El Calendario Grid -->
                <GridLayout
                    android:id="@+id/gridCalendario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:columnCount="7"
                    android:paddingHorizontal="12dp"
                    app:layout_constraintTop_toBottomOf="@id/llDiasSemana" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sección de Eventos -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/nsvEventos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:fillViewport="true"
            android:background="@drawable/bottom_sheet_bg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cvContenedorCalendario">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvEtiquetaDia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.1"
                        android:text="HOY"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        android:id="@+id/tvNumeroDia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25"
                        android:textColor="#FF0000"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvEtiquetaDia" />
                    <TextView
                        android:id="@+id/tvNombreDia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lunes"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvNumeroDia" />
                    <TextView
                        android:id="@+id/tvResumenEventos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="Cargando recordatorios..."
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        app:layout_constraintBottom_toBottomOf="@id/tvNumeroDia"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvNumeroDia"
                        app:layout_constraintTop_toTopOf="@id/tvNumeroDia" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEventosTratamiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp"
                    tools:listitem="@layout/item_evento_tratamiento" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAgregarTratamiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="#2D3243"
            app:elevation="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/white"
            android:contentDescription="Añadir" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.drawerlayout.widget.DrawerLayout>
