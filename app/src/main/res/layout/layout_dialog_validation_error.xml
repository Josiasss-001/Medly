<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Top handle bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="20dp"/>

        <!-- Error Icon -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="32dp"
            app:cardBackgroundColor="#FDECEA"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/stat_notify_error"
                app:tint="#D32F2F" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvErrorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No se detectó información válida"
            android:textColor="#0D1B2A"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="El archivo seleccionado no corresponde a un documento médico válido o no contiene información suficiente para ser procesado."
            android:textColor="#5E6C84"
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"/>

        <!-- Rescan Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnRescan"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="27dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E0F2F1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="VOLVER A ESCANEAR"
                android:textColor="#008080"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Cancel Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnCancelError"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            app:cardCornerRadius="27dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#FBDEDE"
            app:cardBackgroundColor="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="CANCELAR"
                android:textColor="#D32F2F"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
