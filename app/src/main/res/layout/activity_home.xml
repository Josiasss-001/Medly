<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.HomeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <!-- CABECERA ESTÁTICA - FIJA ARRIBA -->

        <!-- CONTENIDO DESLIZABLE -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#53c899"
            android:paddingTop="90dp"
            android:paddingBottom="40dp"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout_editor_absoluteX="0dp">

            <!-- BOTÓN NAVIZQUIEDA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navizquieda"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="Abrir menú"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>

            <!-- BOTÓN NOTIFICACIONES -->
            <FrameLayout
                android:id="@+id/btnNotificationBell"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="20dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/navizquieda"
                app:layout_constraintBottom_toBottomOf="@id/navizquieda">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottieBell"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp"
                    app:lottie_autoPlay="true"
                    app:lottie_colorFilter="@color/white"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/campana" />

                <View
                    android:id="@+id/notifBadgeIndicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/dot_red"
                    android:visibility="gone" />
            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toEndOf="@id/navizquieda"
                app:layout_constraintTop_toTopOf="@id/navizquieda">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileCircle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Perfil"
                    android:scaleType="centerCrop"
                    android:src="@drawable/monito" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/IIgreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/cardProfile"
                app:layout_constraintStart_toEndOf="@id/cardProfile"
                app:layout_constraintTop_toTopOf="@id/cardProfile">

                <TextView
                    android:id="@+id/userNameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hola, Usuario"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/tvSubGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Empecemos con tu salud!"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cardProfile">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Buscar"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#888888" />

                    <EditText
                        android:id="@+id/searchEditText"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:autofillHints="none"
                        android:background="@null"
                        android:hint="Buscar servicios..."
                        android:inputType="text"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/suggestionsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/searchCard">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="200dp"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="-28dp"
            android:fillViewport="true"
            android:paddingBottom="100dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            app:layout_constraintTop_toBottomOf="@id/appBarLayout"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F8F9FA"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:shapeAppearanceOverlay="@style/TopRoundedCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:paddingBottom="20dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <TextView
                        android:id="@+id/tvNoResults"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="50dp"
                        android:text="Sin resultados."
                        android:textColor="#999999"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpBannerCarousel"
                        android:layout_width="match_parent"
                        android:layout_height="222dp"
                        android:layout_marginTop="-40dp"
                        android:elevation="8dp"
                        android:paddingHorizontal="0dp"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:id="@+id/layoutDots"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-40dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:elevation="10dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/vpBannerCarousel" />

                    <TextView
                        android:id="@+id/tvQuick"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="-10dp"
                        android:text="Servicios destacados"
                        android:textColor="#1E293B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/vpBannerCarousel" />

                    <GridLayout
                        android:id="@+id/gridCategories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:layout_marginTop="5dp"
                        android:columnCount="4"
                        app:layout_constraintTop_toBottomOf="@id/tvQuick"
                        tools:layout_editor_absoluteX="16dp">

                        <!-- RECETAS -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnRecetasHome"
                            android:layout_width="0dp"
                            android:layout_height="85dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:strokeColor="#F1F5F9"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="75dp"
                                android:layout_height="90dp"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="4dp">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:contentDescription="Recetas"
                                    android:src="@drawable/archivo" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:gravity="center"
                                    android:text="Recetas"
                                    android:textColor="#334155"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- CITAS MÉDICAS -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnCitasHome"
                            android:layout_width="0dp"
                            android:layout_height="85dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:strokeColor="#F1F5F9"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="4dp">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:contentDescription="Citas Médicas"
                                    android:src="@drawable/calendario" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:gravity="center"
                                    android:text="Citas"
                                    android:textColor="#334155"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- CALENDARIO DE TRATAMIENTO -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnTratamientoHome"
                            android:layout_width="0dp"
                            android:layout_height="85dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:strokeColor="#F1F5F9"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="4dp">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:contentDescription="Calendario de Tratamiento"
                                    android:src="@drawable/pildora" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:gravity="center"
                                    android:text="Tratamiento"
                                    android:textColor="#334155"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- INFORME CLÍNICO -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnCredencialHome"
                            android:layout_width="0dp"
                            android:layout_height="85dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:strokeColor="#F1F5F9"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="4dp">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:contentDescription="Informe de Análisis Clínico"
                                    android:src="@drawable/credencial" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:gravity="center"
                                    android:text="Informe"
                                    android:textColor="#334155"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/clHealthSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        app:layout_constraintTop_toBottomOf="@id/gridCategories">

                        <TextView
                            android:id="@+id/tvHealthSummaryTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="24dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="Resumen de salud"
                            android:textColor="#1E293B"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnVerMasSalud"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="24dp"
                            android:text="Ver más >"
                            android:textColor="@color/Celeste"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="@id/tvHealthSummaryTitle"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tvHealthSummaryTitle" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="0dp"
                            android:layout_marginTop="-10dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="6dp"
                            app:cardUseCompatPadding="true"
                            app:layout_constraintTop_toBottomOf="@id/tvHealthSummaryTitle"
                            app:strokeColor="#F1F5F9"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingVertical="12dp">

                                <!-- Peso -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:contentDescription="Peso"
                                        android:src="@drawable/balanza"
                                        app:tint="@color/Celeste" />

                                    <TextView
                                        android:id="@+id/tvPesoHome"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="-- kg"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Peso"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="40dp"
                                    android:background="#F1F5F9" />

                                <!-- Altura -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:contentDescription="Altura"
                                        android:src="@drawable/estatura"
                                        app:tint="@color/Celeste" />

                                    <TextView
                                        android:id="@+id/tvAlturaHome"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="-- m"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Altura"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="40dp"
                                    android:background="#F1F5F9" />

                                <!-- IMC -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:contentDescription="IMC"
                                        android:src="@drawable/hombre"
                                        app:tint="@color/Celeste" />

                                    <TextView
                                        android:id="@+id/tvIMCHome"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="--"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="IMC"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/tvIMCEstadoHome"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:background="@drawable/badge_rounded_bg"
                                        android:backgroundTint="#FEF3C7"
                                        android:paddingHorizontal="6dp"
                                        android:paddingVertical="1dp"
                                        android:text="--"
                                        android:textColor="#D97706"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="40dp"
                                    android:background="#F1F5F9" />

                                <!-- Enfermedad -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.2"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:contentDescription="Enfermedad"
                                        android:src="@drawable/heart"
                                        app:tint="#F87171" />

                                    <TextView
                                        android:id="@+id/tvEnfermedadHome"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:ellipsize="end"
                                        android:gravity="center"
                                        android:maxLines="1"
                                        android:text="--"
                                        android:textColor="#1E293B"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="Enfermedad"
                                        android:textColor="#94A3B8"
                                        android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- SECCIÓN: ALERTAS IMPORTANTES -->
                    <LinearLayout
                        android:id="@+id/llAlertasHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/clHealthSummary">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alertas importantes"
                            android:textColor="#1E293B"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAlertas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:nestedScrollingEnabled="false"
                        app:layout_constraintTop_toBottomOf="@id/llAlertasHeader" />

                    <LinearLayout
                        android:id="@+id/llNotifHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginTop="15dp"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/rvAlertas">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Notificaciones"
                                android:textColor="#1E293B"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvNotifCounter"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/badge_rounded_bg"
                                android:backgroundTint="#FF5252"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpHomeCarousel"
                        android:layout_width="match_parent"
                        android:layout_height="240dp"
                        android:layout_marginTop="10dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:elevation="6dp"
                        android:paddingHorizontal="0dp"
                        app:layout_constraintTop_toBottomOf="@id/llNotifHeader" />

                    <TextView
                        android:id="@+id/tvStats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="28dp"
                        android:text="Resumen Semanal"
                        android:textColor="#1E293B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/vpHomeCarousel" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statsCard"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tvStats">
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PROGRESO"
                                android:textColor="@color/Celeste"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal"
                                android:gravity="bottom"
                                android:weightSum="7">
                                <View android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:layout_margin="3dp" android:background="@color/Celeste" android:alpha="0.2"/>
                                <View android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_margin="3dp" android:background="@color/Celeste" android:alpha="0.4"/>
                                <View android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:layout_margin="3dp" android:background="@color/Celeste" />
                                <View android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:layout_margin="3dp" android:background="@color/Celeste" android:alpha="0.6"/>
                                <View android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1" android:layout_margin="3dp" android:background="@color/Celeste" />
                                <View android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:layout_margin="3dp" android:background="@color/Celeste" android:alpha="0.3"/>
                                <View android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:layout_margin="3dp" android:background="@color/Celeste" />
                            </LinearLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.core.widget.NestedScrollView>

        <!-- BARRA DE NAVEGACIÓN REUTILIZABLE -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">
            <include layout="@layout/layout_navegacion_personalizada" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
