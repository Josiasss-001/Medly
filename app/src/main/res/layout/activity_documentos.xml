<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.DocumentosActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <!-- FONDO DE CABECERA CON COLOR Y DIFUMINADO -->
        <View
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="#53c899" />

        <View
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="@drawable/gradient_white_overlay"
            android:backgroundTint="#F8F9FA" />

        <!-- BOTÓN DE MENÚ HAMBURGUESA -->
        <ImageView
            android:id="@+id/menuIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="50dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menú"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/white"
            android:elevation="10dp"/>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="100dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"
                android:paddingTop="100dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/tvTituloDocumentos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="Documentos"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSubtituloDocumentos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="Todos tus documentos médicos en un solo lugar"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <!-- BARRA DE BÚSQUEDA TIPO HOME -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="20dp">

                    <LinearLayout
                        android:id="@+id/searchContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="2dp"
                        app:layout_constraintTop_toTopOf="parent">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/searchCard"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="3dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#F1F5F9"
                            app:cardBackgroundColor="@color/white">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="16dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@android:drawable/ic_menu_search"
                                    app:tint="#64748B"
                                    android:contentDescription="Buscar" />

                                <EditText
                                    android:id="@+id/etSearchDocs"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_marginStart="8dp"
                                    android:background="@null"
                                    android:hint="Buscar por nombre o doctor..."
                                    android:textSize="14sp"
                                    android:textColor="#1E293B"
                                    android:textColorHint="#94A3B8"
                                    android:inputType="text"
                                    android:importantForAutofill="no" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/suggestionsCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="8dp"
                        app:layout_constraintTop_toBottomOf="@id/searchContainer"
                        app:layout_constraintStart_toStartOf="@id/searchContainer"
                        app:layout_constraintEnd_toEndOf="@id/searchContainer">
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvSuggestions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxHeight="250dp"
                            android:padding="8dp" />
                    </com.google.android.material.card.MaterialCardView>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="8dp"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupDocs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTodos"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Todos"
                            android:checked="true"
                            app:chipBackgroundColor="@color/Celeste"
                            android:textColor="@color/white" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipRecetas"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recetas" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCitas"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Citas" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipExamenes"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Exámenes" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCertificados"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Certificados" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipOrdenes"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Órdenes" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <!-- VISTA PRINCIPAL: DASHBOARD -->
                <LinearLayout
                    android:id="@+id/layoutDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:visibility="visible">

                    <!-- FrameLayout que contiene los botones y la carga local -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <GridLayout
                            android:id="@+id/gridLayoutCategorias"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="3">

                            <!-- Card Recetas -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnCardRecetas"
                                android:layout_width="0dp"
                                android:layout_height="170dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="6dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                app:strokeWidth="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="45dp"
                                        android:layout_height="45dp"
                                        app:cardBackgroundColor="#F1F8F7"
                                        app:cardCornerRadius="12dp"
                                        app:cardElevation="0dp"
                                        app:strokeWidth="0dp">
                                        <ImageView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="10dp"
                                            android:src="@drawable/archivo"
                                            app:tint="@color/Celeste"
                                            android:contentDescription="Recetas" />
                                    </com.google.android.material.card.MaterialCardView>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="Recetas"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#1E293B" />
                                    <TextView
                                        android:id="@+id/tvCountRecetas"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Recetas médicas escaneadas"
                                        android:textColor="#94A3B8"
                                        android:textSize="8sp"
                                        android:gravity="center"
                                        android:layout_marginTop="2dp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Card Citas -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnCardCitas"
                                android:layout_width="0dp"
                                android:layout_height="170dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="6dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                app:strokeWidth="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="45dp"
                                        android:layout_height="45dp"
                                        app:cardBackgroundColor="#F1F5F9"
                                        app:cardCornerRadius="12dp"
                                        app:cardElevation="0dp"
                                        app:strokeWidth="0dp">
                                        <ImageView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="10dp"
                                            android:src="@drawable/calendario"
                                            android:contentDescription="Citas" />
                                    </com.google.android.material.card.MaterialCardView>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="Citas médicas"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#1E293B"
                                        android:gravity="center" />
                                    <TextView
                                        android:id="@+id/tvCountCitas"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Horas y controles programados"
                                        android:textColor="#94A3B8"
                                        android:textSize="8sp"
                                        android:gravity="center"
                                        android:layout_marginTop="2dp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Card Exámenes -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnCardExamenes"
                                android:layout_width="0dp"
                                android:layout_height="170dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="6dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                app:strokeWidth="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="45dp"
                                        android:layout_height="45dp"
                                        app:cardBackgroundColor="#F5F3FF"
                                        app:cardCornerRadius="12dp"
                                        app:cardElevation="0dp"
                                        app:strokeWidth="0dp">
                                        <ImageView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="10dp"
                                            android:src="@drawable/examen"
                                            android:contentDescription="Exámenes" />
                                    </com.google.android.material.card.MaterialCardView>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="Exámenes"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#1E293B" />
                                    <TextView
                                        android:id="@+id/tvCountExamenes"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Resultados y órdenes de exámenes"
                                        android:textColor="#94A3B8"
                                        android:textSize="8sp"
                                        android:gravity="center"
                                        android:layout_marginTop="2dp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Card Certificados -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnCardCertificados"
                                android:layout_width="0dp"
                                android:layout_height="170dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="6dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                app:strokeWidth="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="45dp"
                                        android:layout_height="45dp"
                                        app:cardBackgroundColor="#FFFBEB"
                                        app:cardCornerRadius="12dp"
                                        app:cardElevation="0dp"
                                        app:strokeWidth="0dp">
                                        <ImageView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="10dp"
                                            android:src="@drawable/archivo"
                                            app:tint="#F59E0B"
                                            android:contentDescription="Certificados" />
                                    </com.google.android.material.card.MaterialCardView>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="Certificados"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#1E293B" />
                                    <TextView
                                        android:id="@+id/tvCountCertificados"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Certificados y documentos"
                                        android:textColor="#94A3B8"
                                        android:textSize="8sp"
                                        android:gravity="center"
                                        android:layout_marginTop="2dp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Card Órdenes -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnCardOrdenes"
                                android:layout_width="0dp"
                                android:layout_height="170dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="6dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                app:strokeWidth="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="45dp"
                                        android:layout_height="45dp"
                                        app:cardBackgroundColor="#FEF2F2"
                                        app:cardCornerRadius="12dp"
                                        app:cardElevation="0dp"
                                        app:strokeWidth="0dp">
                                        <ImageView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="10dp"
                                            android:src="@drawable/archivo"
                                            app:tint="#EF4444"
                                            android:contentDescription="Órdenes" />
                                    </com.google.android.material.card.MaterialCardView>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Órdenes médicas"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#1E293B"
                                        android:gravity="center" />
                                    <TextView
                                        android:id="@+id/tvCountOrdenes"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Órdenes e indicaciones médicas"
                                        android:textColor="#94A3B8"
                                        android:textSize="8sp"
                                        android:gravity="center"
                                        android:layout_marginTop="2dp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Card Otros -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnCardOtros"
                                android:layout_width="0dp"
                                android:layout_height="170dp"
                                android:layout_columnWeight="1"
                                android:layout_margin="6dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="4dp"
                                app:strokeWidth="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="45dp"
                                        android:layout_height="45dp"
                                        app:cardBackgroundColor="#F8FAFC"
                                        app:cardCornerRadius="12dp"
                                        app:cardElevation="0dp"
                                        app:strokeWidth="0dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:padding="10dp"
                                        android:src="@drawable/caja"
                                        android:contentDescription="Otros" />
                                    </com.google.android.material.card.MaterialCardView>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="Otros"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#1E293B" />
                                    <TextView
                                        android:id="@+id/tvCountOtros"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textColor="#1E293B"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Otros documentos importantes"
                                        android:textColor="#94A3B8"
                                        android:textSize="8sp"
                                        android:gravity="center"
                                        android:layout_marginTop="2dp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </GridLayout>

                        <!-- PANTALLA DE CARGA LOCAL DIFUMINADA (FONDO BLANCO) -->
                        <FrameLayout
                            android:id="@+id/loadingOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="visible"
                            android:background="#FFFFFF"
                            android:clickable="true"
                            android:focusable="true">

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/lottieLoading"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="20dp"
                                app:lottie_autoPlay="true"
                                app:lottie_loop="true"
                                app:lottie_rawRes="@raw/cargando" />
                        </FrameLayout>

                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/layoutHeaderSeccion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:layout_marginHorizontal="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvTituloSeccion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Recientes"
                            android:textColor="#1E293B"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnVerTodosDocs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VER TODOS"
                            android:textColor="#53c899"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentDocs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        tools:listitem="@layout/item_documento" />

                    <!-- Mensaje de no resultados para la búsqueda -->
                    <TextView
                        android:id="@+id/tvNoResults"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp"
                        android:text="No se encontraron documentos con ese nombre."
                        android:textAlignment="center"
                        android:textColor="#94A3B8"
                        android:visibility="gone" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardSeguridad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginHorizontal="8dp"
                        app:cardBackgroundColor="#F1F8F7"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_lock_idle_lock"
                                app:tint="#53c899"
                                android:contentDescription="Seguridad" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tus documentos están seguros"
                                    android:textColor="#1E293B"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Toda tu información está encriptada y protegida"
                                    android:textColor="#64748B"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_media_play"
                                app:tint="#53c899"
                                android:contentDescription="Ver más" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- CONTENIDO DINÁMICO: RECETAS -->
                <LinearLayout
                    android:id="@+id/layoutRecetasContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginHorizontal="4dp"
                        android:text="Mis Recetas Médicas"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecetasUnificadas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" />
                    <ProgressBar
                        android:id="@+id/loadingRecetasUnificadas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/tvEmptyRecetas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="No tienes recetas guardadas"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- CONTENIDO DINÁMICO: CITAS -->
                <LinearLayout
                    android:id="@+id/layoutCitasContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginHorizontal="4dp"
                        android:text="Mis Citas Médicas"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvRecienAgregadoUnificado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginHorizontal="4dp"
                        android:text="Recién agregado"
                        android:textColor="#E57373"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                    <include
                        android:id="@+id/itemRecienteUnificado"
                        layout="@layout/item_cita_grande"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/tvOtrasCitasUnificado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginHorizontal="4dp"
                        android:text="Otras citas"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCitasUnificadas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddDocumento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="140dp"
            android:src="@android:drawable/ic_input_add"
            android:visibility="gone"
            app:backgroundTint="@color/Celeste"
            app:tint="@color/white"
            android:contentDescription="Agregar documento" />

        <!-- BARRA DE NAVEGACIÓN REUTILIZABLE -->
        <include layout="@layout/layout_navegacion_personalizada" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>