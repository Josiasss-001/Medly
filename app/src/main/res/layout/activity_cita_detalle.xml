<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".ui.CitaDetalleActivity">

    <!-- Contenido Scrolleable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewCita"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Imagen Superior (Header) -->
            <ImageView
                android:id="@+id/appointmentLargeImage"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:scaleType="centerCrop"
                android:background="#EEEEEE"
                android:contentDescription="Foto de cita médica"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Capa de difuminado visual (Degradado) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="@drawable/gradient_blur_overlay"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Tarjeta de Información Superpuesta -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                app:cardCornerRadius="40dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@+id/appointmentLargeImage">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@color/white">

                    <!-- Indicador superior -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="20dp"
                        android:background="#EEEEEE" />

                    <!-- Título (Especialidad) Editable -->
                    <EditText
                        android:id="@+id/appointmentSpecialtyDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Analizando cita..."
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textCapWords"
                        android:autofillHints="none" />

                    <!-- Nombre del Médico -->
                    <EditText
                        android:id="@+id/appointmentDoctorDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Médico asignado aparecerá aquí."
                        android:textAlignment="center"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textPersonName"
                        android:autofillHints="none" />

                    <!-- Centro Médico (En pequeño debajo del médico) -->
                    <EditText
                        android:id="@+id/centerText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="--"
                        android:textAlignment="center"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="text"
                        android:autofillHints="none" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="#F0F0F0" />

                    <!-- Datos en Formato Lista Vertical -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <!-- Item: Fecha -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Fecha"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/dateText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="date"
                                android:autofillHints="none" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9"/>

                        <!-- Item: Hora -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Hora"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/hourText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="time"
                                android:autofillHints="none" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9"/>

                        <!-- Item: Motivo -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Motivo Consulta"
                                android:textColor="#666666"
                                android:textSize="15sp" />
                            <EditText
                                android:id="@+id/reasonText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:minWidth="60dp"
                                android:gravity="end"
                                android:inputType="text"
                                android:autofillHints="none" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="#F0F0F0" />

                    <!-- Sección: Instrucciones Previas -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Instrucciones Previas"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/instructionsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Cargando instrucciones adicionales..."
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textMultiLine"
                        android:autofillHints="none" />

                    <!-- Botones de Acción -->
                    <View android:layout_width="match_parent" android:layout_height="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReanalizarCita"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="VOLVER A ANALIZAR"
                        android:textColor="@color/Celeste"
                        app:strokeColor="@color/Celeste"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnGuardarCita"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#333333"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GUARDAR CITA"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditarCita"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:text="EDITAR INFORMACIÓN"
                        android:textColor="@color/Celeste"
                        android:textStyle="bold"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEliminarCita"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="4dp"
                        android:text="ELIMINAR CITA"
                        android:textColor="#FF3B30"
                        android:textStyle="bold"
                        app:cornerRadius="20dp" />

                    <View android:layout_width="match_parent" android:layout_height="80dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón Volver Flotante (Actualizado a estilo moderno) -->
    <ImageButton
        android:id="@+id/backButtonCitaDetail"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/abc_ic_ab_back_material"
        android:contentDescription="Atrás"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <!-- Cargando Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loadingCitaOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6FFFFFF"
        android:visibility="gone"
        android:elevation="10dp">
        <ProgressBar
            android:id="@+id/progressBarCita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/Celeste"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="La IA está leyendo tu cita médica..."
            android:textColor="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressBarCita" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
