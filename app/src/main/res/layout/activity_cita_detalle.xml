<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".ui.CitaDetalleActivity">

    <!-- Contenido Scrolleable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewCita"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Imagen Superior (Header) con efecto Parallax -->
            <ImageView
                android:id="@+id/appointmentLargeImage"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:scaleType="centerCrop"
                android:background="#EEEEEE"
                android:contentDescription="Foto de cita médica"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Capa de difuminado visual (Degradado) -->
            <View
                android:id="@+id/gradientOverlay"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:background="@drawable/gradient_blur_overlay"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Tarjeta de Información Superpuesta -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-60dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@+id/appointmentLargeImage">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:background="@color/white">

                    <!-- Indicador superior elegante -->
                    <View
                        android:layout_width="48dp"
                        android:layout_height="5dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="24dp"
                        android:background="#E0E0E0" />

                    <!-- Título (Especialidad) -->
                    <EditText
                        android:id="@+id/appointmentSpecialtyDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Especialidad"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textCapWords"
                        android:autofillHints="none"
                        android:letterSpacing="-0.02" />

                    <!-- Nombre del Médico -->
                    <EditText
                        android:id="@+id/appointmentDoctorDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Médico asignado"
                        android:textAlignment="center"
                        android:textColor="#5F6368"
                        android:textSize="16sp"
                        android:background="@null"
                        android:enabled="false"
                        android:inputType="textPersonName"
                        android:autofillHints="none" />

                    <!-- Centro Médico y Dirección -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="6dp"
                        android:gravity="center">

                        <EditText
                            android:id="@+id/centerText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#80868B"
                            android:textSize="14sp"
                            android:background="@null"
                            android:enabled="false"
                            android:inputType="text"
                            android:autofillHints="none" />

                        <EditText
                            android:id="@+id/addressText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="--"
                            android:textColor="#9AA0A6"
                            android:textSize="13sp"
                            android:background="@null"
                            android:enabled="false"
                            android:inputType="text"
                            android:autofillHints="none" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="12dp"
                        android:background="#F1F3F4" />

                    <!-- Lista de Detalles con mejor jerarquía -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Item: Fecha -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fecha de cita"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_alignParentStart="true" />
                            <EditText
                                android:id="@+id/dateText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:layout_alignParentEnd="true"
                                android:inputType="date" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8F9FA"/>

                        <!-- Item: Hora -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hora programada"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_alignParentStart="true" />
                            <EditText
                                android:id="@+id/hourText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:background="@null"
                                android:enabled="false"
                                android:layout_alignParentEnd="true"
                                android:inputType="time" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8F9FA"/>

                        <!-- Item: Motivo -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Motivo de la consulta"
                                android:textColor="#5F6368"
                                android:textSize="15sp"
                                android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/reasonText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:background="@null"
                                android:enabled="false"
                                android:inputType="textMultiLine" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="12dp"
                        android:background="#F1F3F4" />

                    <!-- Sección: Instrucciones Previas -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Instrucciones Previas"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/instructionsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="12dp"
                        android:text="--"
                        android:textColor="#5F6368"
                        android:textSize="15sp"
                        android:background="@drawable/rounded_dialog_bg"
                        android:backgroundTint="#F8F9FA"
                        android:enabled="false"
                        android:inputType="textMultiLine"
                        android:lineSpacingExtra="4dp" />

                    <!-- Acciones Finales Modernizadas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGuardarCita"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:text="GUARDAR CITA"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/Celeste"
                            app:cornerRadius="18dp"
                            app:elevation="4dp"
                            android:letterSpacing="0.05" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditarCita"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:layout_marginTop="16dp"
                            android:text="EDITAR INFORMACIÓN"
                            android:textColor="@color/Celeste"
                            android:textStyle="bold"
                            app:cornerRadius="18dp"
                            app:strokeColor="@color/Celeste"
                            app:strokeWidth="2dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnReanalizarCita"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="RE-ANALIZAR"
                                android:textColor="#80868B"
                                android:textSize="13sp"
                                app:icon="@android:drawable/ic_menu_rotate"
                                app:iconTint="#80868B"
                                app:iconGravity="textStart" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="24dp"
                                android:background="#DADCE0" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnEliminarCita"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="ELIMINAR"
                                android:textColor="#D93025"
                                android:textSize="13sp"
                                app:icon="@android:drawable/ic_menu_delete"
                                app:iconTint="#D93025"
                                app:iconGravity="textStart" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Padding inferior extra para scroll fluido -->
                    <View android:layout_width="match_parent" android:layout_height="40dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón de Volver Refinado -->
    <ImageButton
        android:id="@+id/backButtonCitaDetail"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:background="@drawable/circle_white_bg"
        android:elevation="8dp"
        android:src="@drawable/abc_ic_ab_back_material"
        android:padding="12dp"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Volver"
        app:tint="#1E293B" />

    <!-- Overlay de Carga Moderno -->
    <FrameLayout
        android:id="@+id/loadingCitaOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:elevation="25dp">
        <com.airbnb.lottie.LottieAnimationView
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/cargando" />
    </FrameLayout>

    <!-- Overlay de Análisis IA Refinado -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/analyzingCitaOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        android:elevation="30dp"
        android:clickable="true"
        android:focusable="true">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieAnalyzing"
            android:layout_width="280dp"
            android:layout_height="280dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/cargando"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.4" />

        <TextView
            android:id="@+id/tvAnalyzingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Interpretando tu cita médica..."
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lottieAnalyzing" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:text="Esto tomará solo unos segundos"
            android:textColor="#5F6368"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAnalyzingTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
